    <!-- Report Title -->
    <title>
        <band height="100">
            <!-- Company Logo -->
            <image hAlign="Center" vAlign="Middle">
                <reportElement x="0" y="0" width="555" height="50"/>
                <imageExpression><![CDATA[$P{logo_path}]]></imageExpression>
            </image>
            
            <!-- Consolidate Title: Salary Slip for <month> -->
            <textField>
                <reportElement x="0" y="60" width="555" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Salary Slip for " + ($P{salary_month} != null ? $P{salary_month} : "Unknown Month")]]></textFieldExpression>
            </textField>
            
            <line>
                <reportElement x="0" y="95" width="555" height="1"/>
                <graphicElement><pen lineWidth="1.0" lineColor="#666666"/></graphicElement>
            </line>
        </band>
    </title>

