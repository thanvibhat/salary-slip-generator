                <textFieldExpression><![CDATA[$P{Total Deductions}]]></textFieldExpression>
            </textField>

            <!-- Payable Salary HIGHLIGHTED Box (Left side) -->
            <rectangle>
                <reportElement x="0" y="65" width="270" height="35" backcolor="#E8F4F8"/>
                <graphicElement><pen lineWidth="1.0" lineColor="#999999"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="5" y="65" width="120" height="35">
                    <printWhenExpression><![CDATA[$P{Payable Salary} != null && !$P{Payable Salary}.trim().isEmpty()]]></printWhenExpression>
                </reportElement>
                <textElement verticalAlignment="Middle"><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Payable Salary]]></text>
            </staticText>
            <textField>
                <reportElement x="125" y="65" width="140" height="35">
                    <printWhenExpression><![CDATA[$P{Payable Salary} != null && !$P{Payable Salary}.trim().isEmpty()]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="14" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{Payable Salary}]]></textFieldExpression>
            </textField>

            <!-- Annual Bonus and Closing Loan Balance (Right side) -->
            <staticText>
                <reportElement x="285" y="65" width="160" height="15">
                    <printWhenExpression><![CDATA[$P{Annual Bonus} != null && !$P{Annual Bonus}.trim().isEmpty()]]></printWhenExpression>
                </reportElement>
                <textElement verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[Annual Bonus]]></text>
            </staticText>
            <textField>
                <reportElement x="445" y="65" width="110" height="15">
                    <printWhenExpression><![CDATA[$P{Annual Bonus} != null && !$P{Annual Bonus}.trim().isEmpty()]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{Annual Bonus}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="285" y="80" width="160" height="15">
                    <printWhenExpression><![CDATA[$P{Closing Loan Balance} != null && !$P{Closing Loan Balance}.trim().isEmpty()]]></printWhenExpression>
                </reportElement>
                <textElement verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[Closing Loan Balance]]></text>
            </staticText>
            <textField>
                <reportElement x="445" y="80" width="110" height="15">
                    <printWhenExpression><![CDATA[$P{Closing Loan Balance} != null && !$P{Closing Loan Balance}.trim().isEmpty()]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{Closing Loan Balance}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
